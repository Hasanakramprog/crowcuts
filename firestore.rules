rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────────
    // USERS — Each user manages their own profile; admin reads all
    // ─────────────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      // Create: only the user themselves (registration / Google sign-in)
      allow create: if request.auth != null &&
        request.auth.uid == userId;
      // Update: own profile (any field), or admin
      // Note: We allow users to update their full profile because Google sign-in
      // and authStateChanges can race to write the document on first login.
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─────────────────────────────────────────────────────────────────────────
    // SERVICES — Readable by all authenticated; admin manages
    // ─────────────────────────────────────────────────────────────────────────
    match /services/{serviceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─────────────────────────────────────────────────────────────────────────
    // BARBERS — Readable and writable by any authenticated user
    // (Only staff have accounts in this private barbershop app)
    // ─────────────────────────────────────────────────────────────────────────
    match /barbers/{barberId} {
      allow read, write: if request.auth != null;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // BOOKINGS — All authenticated users can read (for slot availability calculation)
    // Customers own their bookings; barbers see assigned; admin manages all
    // ─────────────────────────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      // Allow all authenticated users to read bookings
      // This is required for customers to see which time slots are occupied
      // when booking appointments with any barber
      allow read: if request.auth != null;
      
      // Customers can only create bookings for themselves
      allow create: if request.auth != null &&
        request.resource.data.customerId == request.auth.uid;
      
      // Barbers can update status and cancellationReason of their assigned bookings
      // Customers can cancel their own bookings
      // Admins can update any booking
      allow update: if request.auth != null && (
        // Customer canceling their own booking
        (request.resource.data.customerId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancellationReason'])) ||
        // Barber updating their assigned booking status
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'barber' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancellationReason', 'isRated']) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.barberId == resource.data.barberId) ||
        // Admin can update anything
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─────────────────────────────────────────────────────────────────────────
    // RATINGS — Readable by all; customers create their own; immutable
    // ─────────────────────────────────────────────────────────────────────────
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.customerId == request.auth.uid &&
        request.resource.data.stars >= 1.0 &&
        request.resource.data.stars <= 5.0;
      allow update: if false;      // immutable
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─────────────────────────────────────────────────────────────────────────
    // INCOME RECORDS — Admin reads all; barbers read own; admin/barber/customer create
    // ─────────────────────────────────────────────────────────────────────────
    match /incomeRecords/{recordId} {
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        resource.data.barberId ==
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.barberId
      );
      allow create: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'barber' &&
         request.resource.data.barberId ==
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.barberId) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'customer'
      ) &&
        request.resource.data.keys().hasAll(['bookingId', 'barberId', 'amount', 'date']);
      allow update, delete: if false;   // immutable
    }
  }
}
