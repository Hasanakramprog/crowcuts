rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Barber avatar images
    // - Any authenticated user can read (to display in the app)
    // - Any authenticated user can write (only barbers/admins are authenticated
    //   and only the barber settings screen triggers uploads)
    match /barbers/{barberId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024   // max 5MB
        && request.resource.contentType.matches('image/.*'); // images only
    }
  }
}
